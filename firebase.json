{
  "hosting": {
    "site": "amarhisab",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".github",
      "README.md"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/", "destination": "/index.html" },
      { "source": "/login", "destination": "/login.html" },
      { "source": "/register", "destination": "/register.html" },
      { "source": "/dashboard", "destination": "/dashboard.html" },
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/budget", "destination": "/budget.html" },
      { "source": "/credits", "destination": "/credits.html" },
      { "source": "/expense", "destination": "/expense.html" },
      { "source": "/income", "destination": "/income.html" },
      { "source": "/reports", "destination": "/reports.html" },
      { "source": "/settings", "destination": "/settings.html" },
      { "source": "/wallets", "destination": "/wallets.html" },
      { "source": "/forgot-password", "destination": "/forgot-password.html" }
    ]
  }
}
